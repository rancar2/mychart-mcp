{
  "compilerOptions": {
    "target": "es6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "rootDir": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "moduleResolution": "Node",
    "module": "commonjs",
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "sourceMap": false,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["web/src/*"],
      "@/components/*": ["web/src/components/*"],
      "@/ui/*": ["web/src/components/ui*"],
      "@/lib/*": ["web/src/lib/*"],
      "@/hooks/*": ["web/src/hooks/*"],
      "@/pages/*": ["web/src/pages/*"]
    }
  },
  "include": [
    "index.d.ts",
    "scrapers/**/*.ts",
    "cli/**/*.ts",
    "shared/**/*.ts",
    "web/src/**/*.ts",
    "web/src/**/*.tsx",
    "read-local-passwords/**/*.ts"
  ]
}
